  "description": "reolink",
  "author": {
    "name": "Andy Grundt",
    "email": "andy.grundt@gmail.com"
  },
  "homepage": "https://github.com/aendue/ioBroker.reolink",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "camera",
    "PTZ",
    "motion"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aendue/ioBroker.reolink"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "axios": "^1.13.2",
    "mqtt": "^5.15.0"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.0.0",
    "@alcalzone/release-script-plugin-iobroker": "^4.0.0",
    "@alcalzone/release-script-plugin-license": "^4.0.0",
    "@alcalzone/release-script-plugin-manual-review": "^4.0.0",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.2.0",
    "@iobroker/testing": "^5.2.2",
    "chai": "^4.5.0",
    "chai-as-promised": "^7.1.2",
    "mocha": "^11.7.5",
    "sinon": "^19.0.5",
    "sinon-chai": "^3.7.0",
    "typescript": "^5.9.3"
  },
  "main": "build/main.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*).json",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "build/",
    "lib/neolink-*",
    "io-package.json",
    "LICENSE"
  ],
  "scripts": {
    "test:js": "mocha test/unit --exit",
    "test:package": "mocha test/package --exit",
    "test:unit": "mocha test/unit --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:unit && npm run test:package",
    "check": "tsc --noEmit -p tsconfig.check.json",
    "lint": "eslint -c eslint.config.mjs",
    "build": "tsc -p tsconfig.build.json",
    "translate": "translate-adapter",
    "release": "release-script"
  },
  "bugs": {
    "url": "https://github.com/aendue/ioBroker.reolink/issues"
  },
  "readmeFilename": "README.md"
